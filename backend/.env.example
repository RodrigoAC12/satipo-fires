# ================================================
# CONFIGURACION DE BASE DE DATOS - SATIPO FIRES
# ================================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Reemplaza los valores con tus credenciales
# 3. Asegúrate que PostgreSQL esté corriendo
# ================================================

# Credenciales de PostgreSQL
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5432
DB_NAME=satipo_fires

# Ambiente (development o production)
ENVIRONMENT=development

# URL del Frontend (para CORS en producción)
FRONTEND_URL=http://localhost:5173

# ================================================
# NOTAS IMPORTANTES:
# ================================================
# 1. Si tu contraseña tiene caracteres especiales (ñ, ó, @, %), 
#    el código la codifica automáticamente.
#
# 2. Asegúrate que PostgreSQL esté corriendo en localhost:5432
#
# 3. Crea la base de datos ejecutando:
#    psql -U admin -c "CREATE DATABASE satipo_fires;"
#
# 4. En producción, usa contraseñas fuertes y URLs específicas.
# ================================================
